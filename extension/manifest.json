{
  "manifest_version": 3,
  "name": "Buffmark",
  "description": "Add text to bookmarks from the context menu and paste when you need it.",
  "version": "1.0.0",
  "permissions": [
    "bookmarks",
    "contextMenus",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
